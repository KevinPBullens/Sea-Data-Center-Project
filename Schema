create database sea_data_center;
use sea_data_center;

create table YearlyQuota (
  country varchar(100) not null,
  product varchar(100) not null,
  product_year year not null,
  quota_kg int unsigned ,
  primary key (country,product,product_year)
);

create table MonthlyCatch (
  country varchar(100) not null,
  product varchar(100) not null,
  catch_month varchar(3) not null,
  catch_year year not null,
  catch_kg int unsigned not null,
  primary key (catch_year,catch_month),
  foreign key (country,product,catch_year)
    references YearlyQuota(country,product,product_year)
    on update cascade
    on delete restrict
);

create table MonthlyTradingPrice (
  country varchar(100) not null,
  product varchar(100) not null,
  price_month varchar(3) not null,
  price_year year not null,
  price_euro_kg decimal(10,2) not null,
  primary key (product,price_month,price_year),
  foreign key (product,price_year)
    references YearlyQuota(product,product_year)
    on update cascade
    on delete restrict,
  foreign key (price_month)
    references MonthlyCatch(catch_month)
    on update cascade
    on delete restrict,
);
